    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Playfair Display", serif;
      }

      body {
        background-color: #fdf6f9; /* rosa bem claro */
        padding-top: 110px;
      }

      /* HEADER */
      header {
        position: fixed;
        top: 0;
        width: 100%;
        padding: 20px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #fdf6f9;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      }

      .logo {
        font-size: 28px;
        color: #2e7d32; /* verde */
        font-weight: bold;
        text-decoration: none;
      }

      .navbar a {
        text-decoration: none;
        color: #444;
        font-size: 18px;
        margin-left: 20px;
      }

      .navbar a:hover {
        color: #e91e63; /* rosa */
      }

      /* TÍTULO */
      h1 {
        margin: 30px;
        color: #2e7d32;
      }

      /* BUSCA */
      .procura {
        margin: 0 30px 30px;
      }

      .procura input {
        width: 300px;
        padding: 10px;
        border-radius: 20px;
        border: 2px solid #e91e63;
        outline: none;
      }

      .procura input:focus {
        border-color: #2e7d32;
      }

      /* CARDS */
      .container {
        max-width: 1200px;
        margin: auto;
        padding: 20px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
      }

      .card {
        background: white;
        border-radius: 20px;
        padding: 15px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        transition: 0.3s;
        border: 2px solid #f8bbd0; /* rosa suave */
      }

      .card:hover {
        transform: translateY(-5px);
        border-color: #2e7d32;
      }

      .card img {
        width: 100%;
        height: 250px;
        object-fit: cover;
        border-radius: 10px;
      }

      .card h3 {
        margin-top: 10px;
        color: #2e7d32;
      }

      .info {
        font-size: 14px;
        margin: 5px 0;
        color: #555;
      }

      .btn {
        margin-top: 10px;
        display: inline-block;
        padding: 8px 12px;
        background: #e91e63; /* rosa */
        color: white;
        border-radius: 10px;
        text-decoration: none;
        transition: 0.3s;
      }

      .btn:hover {
        background: #2e7d32; /* vira verde */
      }

      /* FOOTER */
      footer {
        margin-top: 40px;
        padding: 30px;
        text-align: center;
        background: #fce4ec;
        box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.1);
        color: #2e7d32;
      }

      @media (max-width: 900px) {
        .grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 600px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

